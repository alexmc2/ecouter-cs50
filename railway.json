{
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npm run build:backend",
    "watchPatterns": [
      "backend/**",
      "data/processed/**",
      "package.json",
      "package-lock.json",
      "railway.json"
    ]
  },
  "deploy": {
    "startCommand": "npm run start --prefix backend",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
